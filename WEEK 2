<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>La Belle Cuisine - Fine Dining</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:Georgia, serif;
background:linear-gradient(135deg,#008080,#004f4f);
color:#f5f5f5;
line-height:1.6;
}

/* Header */

.header{
text-align:center;
padding:60px 20px 40px;
background:linear-gradient(rgba(0,0,0,0.7),rgba(0,0,0,0.7));
border-bottom:3px solid black;
}

.restaurant-name{
font-size:3.5em;
color:white;
letter-spacing:8px;
margin-bottom:10px;
}

.tagline{
font-size:1.2em;
font-style:italic;
letter-spacing:2px;
}

.location{
margin-top:20px;
color:white;
}

/* Container */

.container{
max-width:1200px;
margin:auto;
padding:40px 20px;
}

/* Categories */

.menu-category{
margin-bottom:60px;
}

.category-title{
font-size:2.5em;
text-align:center;
margin-bottom:30px;
border-bottom:2px solid black;
padding-bottom:10px;
color:black;
letter-spacing:3px;
}

/* Menu items */

.menu-items{
display:grid;
gap:25px;
}

.menu-item{
background:rgba(255,255,255,0.05);
padding:25px;
border-radius:10px;
border-left:4px solid black;
transition:0.3s;
}

.menu-item:hover{
background:rgba(255,255,255,0.1);
transform:translateX(10px);
box-shadow:0 5px 20px rgba(0,0,0,0.4);
}

.item-header{
display:flex;
justify-content:space-between;
margin-bottom:10px;
}

.item-name{
font-size:1.3em;
}

.item-price{
color:black;
font-weight:bold;
}

.item-description{
color:#cccccc;
font-size:0.95em;
font-style:italic;
}

/* Footer */

.footer{
text-align:center;
padding:40px;
background:rgba(0,0,0,0.5);
border-top:2px solid black;
margin-top:60px;
}

.footer-text{
color:black;
margin-bottom:10px;
}

.contact-info{
color:#cccccc;
}

/* Mobile */

@media(max-width:768px){

.restaurant-name{
font-size:2.5em;
letter-spacing:4px;
}

.category-title{
font-size:2em;
}

}

</style>
</head>

<body>

<div class="header">
<h1 class="restaurant-name">LA BELLE CUISINE</h1>
<p class="tagline">Fine Dining Experience</p>
<p class="location">📍 Dharampeth, Nagpur - Maharashtra</p>
</div>

<div class="container">

<!-- Appetizers -->

<div class="menu-category">
<h2 class="category-title">APPETIZERS</h2>

<div class="menu-items">

<div class="menu-item">
<div class="item-header">
<span class="item-name">Bruschetta al Pomodoro</span>
<span class="item-price">₹320</span>
</div>
<p class="item-description">Grilled artisan bread topped with fresh tomatoes, basil, garlic, and olive oil</p>
</div>

<div class="menu-item">
<div class="item-header">
<span class="item-name">Crispy Calamari</span>
<span class="item-price">₹450</span>
</div>
<p class="item-description">Lightly battered squid rings served with tangy marinara sauce</p>
</div>

<div class="menu-item">
<div class="item-header">
<span class="item-name">Cheese Fondue</span>
<span class="item-price">₹550</span>
</div>
<p class="item-description">Blend of Gruyère and Emmental cheese served with bread and vegetables</p>
</div>

</div>
</div>

<!-- Main Course -->

<div class="menu-category">
<h2 class="category-title">MAIN COURSE</h2>

<div class="menu-items">

<div class="menu-item">
<div class="item-header">
<span class="item-name">Grilled Salmon</span>
<span class="item-price">₹850</span>
</div>
<p class="item-description">Atlantic salmon served with asparagus and lemon butter sauce</p>
</div>

<div class="menu-item">
<div class="item-header">
<span class="item-name">Filet Mignon</span>
<span class="item-price">₹1200</span>
</div>
<p class="item-description">Premium beef tenderloin served with mashed potatoes</p>
</div>

<div class="menu-item">
<div class="item-header">
<span class="item-name">Vegetable Wellington</span>
<span class="item-price">₹650</span>
</div>
<p class="item-description">Seasonal vegetables wrapped in flaky puff pastry</p>
</div>

</div>
</div>

<!-- Desserts -->

<div class="menu-category">
<h2 class="category-title">DESSERTS</h2>

<div class="menu-items">

<div class="menu-item">
<div class="item-header">
<span class="item-name">Tiramisu</span>
<span class="item-price">₹380</span>
</div>
<p class="item-description">Italian dessert with espresso soaked biscuits and mascarpone</p>
</div>

<div class="menu-item">
<div class="item-header">
<span class="item-name">Chocolate Lava Cake</span>
<span class="item-price">₹420</span>
</div>
<p class="item-description">Warm chocolate cake with molten center</p>
</div>

</div>
</div>

<!-- Beverages -->

<div class="menu-category">
<h2 class="category-title">BEVERAGES</h2>

<div class="menu-items">

<div class="menu-item">
<div class="item-header">
<span class="item-name">Fresh Coffee</span>
<span class="item-price">₹180</span>
</div>
<p class="item-description">Espresso, cappuccino or latte</p>
</div>

<div class="menu-item">
<div class="item-header">
<span class="item-name">Fresh Fruit Juice</span>
<span class="item-price">₹220</span>
</div>
<p class="item-description">Orange, pineapple or mixed fruit</p>
</div>

</div>
</div>

</div>

<div class="footer">
<p class="footer-text">Open Daily: 12:00 PM - 11:00 PM</p>
<p class="contact-info">Reservations: +91 98765 43210 | labellecuisine@email.com</p>
<p class="contact-info">Near Central Mall, Dharampeth, Nagpur - 440010</p>
</div>

</body>
</html>
